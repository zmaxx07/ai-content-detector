# ═══════════════════════════════════════════════════════════════
#  AI Content Detection Backend — Environment Configuration
#  Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── Required API Keys ──────────────────────────────────────────
# Get free token at: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=

# Get free token at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Optional API Keys ──────────────────────────────────────────
# Get free key at: https://newsapi.org/register
NEWSAPI_KEY=

# For Claude enrichment (optional, advanced)
ANTHROPIC_API_KEY=

# For Sightengine premium image detection (optional)
# Get free keys at: https://sightengine.com
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=

# ── Inference Mode ─────────────────────────────────────────────
# "api"   → Uses HuggingFace Inference API (recommended, no GPU needed)
# "local" → Downloads & runs models on your machine (needs 4GB+ RAM)
INFERENCE_MODE=api

# ── Model Names (leave as default unless you want to swap) ──────
TEXT_MODEL_NAME=roberta-base-openai-detector
TEXT_MODEL_FALLBACK=Hello-SimpleAI/chatgpt-detector-roberta
IMAGE_MODEL_NAME=Organika/sdxl-detector
IMAGE_MODEL_FALLBACK=umm-maybe/AI-image-detector
CODE_MODEL_NAME=roberta-base-openai-detector

# ── Local Inference Settings (only if INFERENCE_MODE=local) ────
# Options: "auto" | "cpu" | "cuda" | "mps"
DEVICE=auto
MAX_TEXT_LENGTH=512

# ── Server Settings ────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
RELOAD=false

# ── Cache ──────────────────────────────────────────────────────
# How long (seconds) to cache fetched human text samples
CACHE_TTL_SECONDS=300
